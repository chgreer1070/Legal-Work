# Flask configuration
FLASK_DEBUG=false

# Converter: max upload requests per IP per minute (default: 10)
RATE_LIMIT_PER_MINUTE=10

# Anthropic API key (optional, for clause extraction and notification generation)
# ANTHROPIC_API_KEY=your_key_here

# FX feed source: "exchangerate_host" (live) or "mock" (demo)
FX_FEED_SOURCE=mock

# Enable/disable APScheduler background jobs
FX_SCHEDULER_ENABLED=false
